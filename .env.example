# Jeremy OS environment variables
# Copy this file to .env.local and fill in values. The app runs fully
# offline with localStorage if these are left blank.

# --- Postgres (Railway) ---
# When set, the full single-user app state is persisted to Postgres and
# synced across devices. On Railway, add a Postgres plugin and reference its
# connection string (DATABASE_URL is provided automatically in that service).
# Leave blank for localStorage-only mode.
DATABASE_URL=
# Set to "true" only for external/public DB connections that require SSL
# (e.g. local dev against Railway's public proxy). Railway's private network
# does not need SSL, so leave blank in production.
DATABASE_SSL=

# --- Passcode lock (recommended for a public deploy) ---
# When set, the whole app (pages + data APIs) is gated behind this passcode.
# Single-user, server-side secret — do NOT prefix with NEXT_PUBLIC_.
# Leave blank to disable the lock (e.g. local dev).
APP_PASSCODE=

# --- Web Push (optional — background reminders) ---
# Generate a keypair:  npx web-push generate-vapid-keys
# Public key is exposed to the browser; private key is a server secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:jeremy@keanonbiz.com
# Shared secret the reminder-cron endpoint requires (?secret=...)
CRON_SECRET=
# IANA timezone reminder times are interpreted in (e.g. America/New_York). UTC if unset.
REMINDER_TZ=

# --- Supabase (optional, alternative to Postgres) ---
# Legacy/alternative cloud backend. Not required when using DATABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- OpenAI (optional, server-side only) ---
# Powers the AI Recovery Coach and voice summaries. When blank, the coach
# falls back to a built-in local reflection engine.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Voice transcription model for /api/transcribe (iOS-reliable voice input).
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Premium text-to-speech for the morning ritual's voice coach (/api/tts).
# When blank, the app falls back to the browser's built-in speech synthesis
# (it auto-selects the most natural installed voice; pick one in the ritual).
# Voice options: alloy, ash, ballad, coral, echo, fable, onyx, nova, sage,
# shimmer, verse. "sage" and "coral" are warm + calm; try a few.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=sage

# --- Slack (optional — the 7am briefing) ---
# A single Slack user token (xoxp-…) for the one-person "read my Slack"
# briefing on the dashboard and at the end of the Morning Ritual. Create a
# Slack app, add user-token read scopes, install it to your workspace, and
# paste the User OAuth Token here. Server-side secret — do NOT prefix with
# NEXT_PUBLIC_. Leave blank to hide the Slack briefing.
# Scopes: channels:read, groups:read, im:read, mpim:read, channels:history,
#         groups:history, im:history, mpim:history, search:read, users:read
SLACK_TOKEN=

# Cowork briefs: the Slack channel (name like "cowork" or its ID) where your
# scheduled Claude Cowork tasks post results. Surfaced above the Slack briefing.
# Uses the SLACK_TOKEN above; can also be set in-app. Leave blank to hide.
COWORK_SLACK_CHANNEL=

# --- Google Calendar (optional — the daily agenda) ---
# A read-only "secret address in iCal format" from Google Calendar
# (Settings → your calendar → Integrate calendar → Secret address in iCal
# format). Powers the Today / Day agenda. You can also paste this in-app
# instead of setting it here. Leave blank to keep the calendar disconnected.
CALENDAR_ICS_URL=

# --- Google Calendar WRITE (optional — schedule blocks from the app) ---
# Lets the app CREATE events (e.g. turn a Cowork/Slack task into a time block).
# Pick ONE auth method. Server-side secrets — never prefix with NEXT_PUBLIC_.
#
# Method A — Service account (QUICKEST, no consent screen, never expires):
#   1. Google Cloud Console → enable the Google Calendar API.
#   2. Create a Service Account → add a JSON key → download it.
#   3. In Google Calendar → Settings → your calendar → "Share with specific
#      people" → add the service account's email → "Make changes to events".
#   4. Paste the whole key JSON below (raw or base64), and set
#      GOOGLE_CALENDAR_ID to your calendar id (usually your Google email).
GOOGLE_SERVICE_ACCOUNT_JSON=
#
# Method B — OAuth refresh token (writes to GOOGLE_CALENDAR_ID, default primary):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Which calendar to write to, and the zone for new events.
# With a service account this MUST be your calendar id (your Google email).
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TZ=America/New_York
