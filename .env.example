# Jeremy OS environment variables
# Copy this file to .env.local and fill in values. The app runs fully
# offline with localStorage if these are left blank.

# --- Postgres (Railway) ---
# When set, the full single-user app state is persisted to Postgres and
# synced across devices. On Railway, add a Postgres plugin and reference its
# connection string (DATABASE_URL is provided automatically in that service).
# Leave blank for localStorage-only mode.
DATABASE_URL=
# Set to "true" only for external/public DB connections that require SSL
# (e.g. local dev against Railway's public proxy). Railway's private network
# does not need SSL, so leave blank in production.
DATABASE_SSL=

# --- Passcode lock (recommended for a public deploy) ---
# When set, the whole app (pages + data APIs) is gated behind this passcode.
# Single-user, server-side secret — do NOT prefix with NEXT_PUBLIC_.
# Leave blank to disable the lock (e.g. local dev).
APP_PASSCODE=

# --- Web Push (optional — background reminders) ---
# Generate a keypair:  npx web-push generate-vapid-keys
# Public key is exposed to the browser; private key is a server secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:jeremy@keanonbiz.com
# Shared secret the reminder-cron endpoint requires (?secret=...)
CRON_SECRET=
# IANA timezone reminder times are interpreted in (e.g. America/New_York). UTC if unset.
REMINDER_TZ=

# --- Supabase (optional, alternative to Postgres) ---
# Legacy/alternative cloud backend. Not required when using DATABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- OpenAI (optional, server-side only) ---
# Powers the AI Recovery Coach and voice summaries. When blank, the coach
# falls back to a built-in local reflection engine.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
